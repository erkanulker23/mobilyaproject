{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "repositories": [ { "type": "composer", "url": "https://packagist.org" } ],
    "require": {
        "php": "^8.2",
        "akaunting/laravel-money": "^5.1",
        "althinect/filament-spatie-roles-permissions": "^2.0",
        "amidesfahani/filament-tinyeditor": "^1.1",
        "archtechx/laravel-seo": "^0.9.0",
        "asantibanez/laravel-eloquent-state-machines": "^5.2",
        "awcodes/filament-curator": "^3.0",
        "awcodes/shout": "^2.0",
        "bensampo/laravel-enum": "^6.3",
        "bezhansalleh/filament-google-analytics": "^2.0",
        "codezero/laravel-localized-routes": "^4.0",
        "cybercog/laravel-eloquent-flag": "^6.0",
        "doctrine/dbal": "^3.0",
        "filament/filament": "^3.3.47",
        "filament/spatie-laravel-google-fonts-plugin": "^3.2",
        "filament/spatie-laravel-media-library-plugin": "^3.2",
        "filament/spatie-laravel-settings-plugin": "^3.2",
        "filament/spatie-laravel-tags-plugin": "^3.2",
        "filament/spatie-laravel-translatable-plugin": "^3.2",
        "google/apiclient": "^2.15",
        "guava/filament-icon-picker": "^2.0",
        "guzzlehttp/guzzle": "^7.2",
        "hexadog/laravel-themes-manager": "^1.10",
        "iyzico/iyzipay-php": "*",
        "kalnoy/nestedset": "^6.0",
        "laravel/framework": "^10.0",
        "laravel/sanctum": "^3.2",
        "laravel/socialite": "^5.8",
        "laravel/tinker": "^2.7",
        "league/flysystem-aws-s3-v3": "3.0",
        "livewire/livewire": "^3.7.5",
        "maatwebsite/excel": "^3.1",
        "matthiasmullie/minify": "^1.3",
        "nwidart/laravel-modules": "^9.0",
        "openai-php/client": "^0.8.4",
        "owenvoke/blade-fontawesome": "^2.6",
        "pxlrbt/filament-spotlight": "^1.2",
        "qirolab/laravel-reactions": "^2.6",
        "riodwanto/filament-ace-editor": "^1.0",
        "rollbar/rollbar-laravel": "^8.0",
        "shetabit/visitor": "^4.3",
        "shipu/web-installer": "^1.0",
        "shuvroroy/filament-spatie-laravel-health": "^2.0",
        "socialiteproviders/google": "^4.1",
        "spatie/eloquent-sortable": "^4.0",
        "spatie/laravel-cookie-consent": "^3.3",
        "spatie/laravel-data": "^3.7",
        "spatie/laravel-honeypot": "^4.5",
        "spatie/laravel-sitemap": "^7.2",
        "spatie/laravel-sluggable": "^3.4",
        "spatie/schema-org": "*",
        "yoeunes/toastr": "^2.3"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.7",
        "fakerphp/faker": "^1.9.1",
        "laravel/breeze": "^1.19",
        "laravel/pint": "^1.2",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^6.1",
        "phpunit/phpunit": "^9.5.10",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [

            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "hexadog/laravel-theme-installer": true,
            "codezero/composer-preload-files": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
